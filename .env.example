# Copy this file to .env and fill in real values. NEVER commit .env.

# --- Required ---
YOUTUBE_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: Reddit source (skipped if absent) ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=ai-video-creator/1.0

# --- Phase 3: video generation ---
# RUNWAY_API_KEY=
# OFFLINE_MODE=true            # true = free stub providers; false = real RunwayML + YouTube
# VIDEO_MODEL=gen4.5
# VIDEO_IMAGE_MODEL=gen4_image
# VIDEO_RATIO=1280:720
# VIDEO_DURATION=5

# --- Phase 5: YouTube posting ---
# POST_INTERVAL_HOURS=8
# YOUTUBE_PRIVACY=private      # private | unlisted | public
# YOUTUBE_CLIENT_SECRETS=secrets/client_secret.json   # OAuth client (Desktop app)
# YOUTUBE_TOKEN_FILE=secrets/youtube_token.json       # created by `python -m posting.authorize`

# --- Optional (sensible defaults applied if omitted) ---
# DATABASE_URL=sqlite:///data/pipeline.db
# ANTHROPIC_MODEL=claude-sonnet-4-6
# LOG_LEVEL=INFO
# DISCOVERY_INTERVAL_HOURS=4
